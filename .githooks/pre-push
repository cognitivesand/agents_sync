#!/usr/bin/env bash
# Pre-push gate: run the local CI (ruff + mypy + full pytest) before every push.
# A non-zero exit aborts the push. Bypass deliberately with `git push --no-verify`.
#
# Enable once per clone (the README Development section documents this):
#   git config core.hooksPath .githooks
set -euo pipefail

ROOT=$(git rev-parse --show-toplevel)
exec "$ROOT/scripts/ci.sh"
